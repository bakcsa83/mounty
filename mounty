#!/usr/bin/env bash
set -euo pipefail

# Mounty - User-friendly CIFS mount manager for Linux
# Uses kernel CIFS mounts instead of GVFS for reliability

CRED_DIR="$HOME/.mounty"
MNT_DIR="$HOME/mnt"
FSTAB="/etc/fstab"
FSTAB_MARKER="mounty"
FSTAB_BEGIN="# >>> mounty managed mounts - do not edit manually >>>"
FSTAB_END="# <<< mounty managed mounts <<<"

# --- Output helpers ---

die() { echo "error: $*" >&2; exit 1; }
info() { echo ":: $*"; }
warn() { echo "warning: $*" >&2; }

# --- Dependency check ---

ensure_deps() {
    if ! command -v mount.cifs &>/dev/null; then
        echo "cifs-utils is not installed."
        read -rp "Install it now? [Y/n] " ans
        if [[ "${ans,,}" != "n" ]]; then
            sudo apt install -y cifs-utils
        else
            die "cifs-utils is required"
        fi
    fi
}

ensure_smbclient() {
    if ! command -v smbclient &>/dev/null; then
        echo "smbclient is not installed (needed for browsing)."
        read -rp "Install it now? [Y/n] " ans
        if [[ "${ans,,}" != "n" ]]; then
            sudo apt install -y smbclient
        else
            die "smbclient is required for browsing"
        fi
    fi
}

# --- Helpers ---

USERNAME_HINT='Username (DOMAIN\user or user@DOMAIN)'

# Parse domain from username input (DOMAIN\user or user@DOMAIN)
# Sets: username, domain
parse_username() {
    local input="$1" default_domain="${2:-WORKGROUP}"
    if [[ "$input" == *\\* ]]; then
        domain="${input%%\\*}"
        username="${input#*\\}"
    elif [[ "$input" == *@* ]]; then
        username="${input%%@*}"
        domain="${input#*@}"
    else
        username="$input"
        domain="$default_domain"
    fi
}

# Detect negotiated SMB version by parsing smbclient debug output.
# Usage: detect_smb_version server [auth_args...]
# Prints the CIFS vers= value (e.g. 3.1.1, 3.0, 2.1) or empty on failure.
detect_smb_version() {
    local server="$1"; shift
    local dialect
    dialect=$(smbclient -L "//$server" "$@" -d 4 2>&1 | grep -oP 'negotiated dialect\[\K[^\]]+' | head -1)

    case "$dialect" in
        SMB3_11)  echo "3.1.1" ;;
        SMB3_02)  echo "3.0.2" ;;
        SMB3_00)  echo "3.0" ;;
        SMB2_10)  echo "2.1" ;;
        SMB2_02)  echo "2.0" ;;
        NT1)      echo "1.0" ;;
        *)        echo "" ;;
    esac
}

share_exists() {
    local name="$1"
    [[ -f "$CRED_DIR/cred-$name" ]]
}

require_share() {
    local name="$1"
    share_exists "$name" || die "share '$name' not found. Run: mounty list"
}

get_fstab_line() {
    local name="$1"
    grep "# ${FSTAB_MARKER}:${name}$" "$FSTAB" 2>/dev/null || true
}

is_mounted() {
    local name="$1"
    mountpoint -q "$MNT_DIR/$name" 2>/dev/null
}

list_shares() {
    [[ -d "$CRED_DIR" ]] || return 0
    find "$CRED_DIR" -maxdepth 1 -name 'cred-*' -printf '%f\n' 2>/dev/null | sed 's/^cred-//' | sort
}

# --- fstab operations ---

automount_unit_name() {
    local name="$1"
    echo "$(systemd-escape -p "$MNT_DIR/$name").automount"
}

automount_start() {
    local name="$1"
    local unit
    unit=$(automount_unit_name "$name")
    sudo systemctl daemon-reload
    sudo systemctl start "$unit"
    info "automount active for $MNT_DIR/$name"
}

automount_stop() {
    local name="$1"
    local unit
    unit=$(automount_unit_name "$name")
    sudo systemctl stop "$unit" 2>/dev/null || true
}

fstab_backup() {
    sudo cp "$FSTAB" "${FSTAB}.bak.mounty"
}

fstab_has_section() {
    grep -qF "$FSTAB_BEGIN" "$FSTAB" 2>/dev/null
}

fstab_ensure_section() {
    if ! fstab_has_section; then
        printf '\n%s\n%s\n' "$FSTAB_BEGIN" "$FSTAB_END" | sudo tee -a "$FSTAB" >/dev/null
    fi
}

fstab_section_is_empty() {
    # Check if there are any non-comment, non-blank lines between the markers
    local content
    content=$(sudo sed -n "/^${FSTAB_BEGIN}$/,/^${FSTAB_END}$/p" "$FSTAB" | grep -v "^#" | grep -v "^$" || true)
    [[ -z "$content" ]]
}

fstab_remove_section() {
    sudo sed -i "/^${FSTAB_BEGIN}$/,/^${FSTAB_END}$/d" "$FSTAB"
    # Remove trailing blank lines left behind
    sudo sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$FSTAB"
}

fstab_add() {
    local name="$1" server="$2" share="$3" vers="$4"
    local cred_file="$CRED_DIR/cred-$name"
    local mnt_point="$MNT_DIR/$name"
    local uid gid
    uid=$(id -u)
    gid=$(id -g)

    local opts="credentials=${cred_file},vers=${vers},uid=${uid},gid=${gid},_netdev,x-systemd.automount,x-systemd.idle-timeout=5min,nofail"
    local entry="//${server}/${share} ${mnt_point} cifs ${opts} 0 0 # ${FSTAB_MARKER}:${name}"

    fstab_backup
    fstab_ensure_section
    # Insert entry before the END marker
    sudo sed -i "/^${FSTAB_END}$/i ${entry}" "$FSTAB"
    info "fstab entry added"
}

fstab_remove() {
    local name="$1"
    if [[ -n "$(get_fstab_line "$name")" ]]; then
        fstab_backup
        sudo sed -i "/# ${FSTAB_MARKER}:${name}$/d" "$FSTAB"
        info "fstab entry removed"
        # Clean up section if no entries remain
        if fstab_section_is_empty; then
            fstab_remove_section
            info "fstab section removed (no shares left)"
        fi
    fi
}

# --- Commands ---

cmd_add() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "usage: mounty add <name>"
    share_exists "$name" && die "share '$name' already exists. Use 'mounty edit $name' or 'mounty remove $name' first"

    ensure_deps

    echo "Adding share: $name"
    echo "---"

    read -rp "Server (hostname or IP): " server
    [[ -z "$server" ]] && die "server is required"

    read -rp "Share name: " share
    [[ -z "$share" ]] && die "share name is required"

    local username="" domain=""
    read -rp "$USERNAME_HINT: " username
    [[ -z "$username" ]] && die "username is required"
    parse_username "$username"

    read -rsp "Password: " password
    echo
    [[ -z "$password" ]] && die "password is required"

    # Detect SMB version
    ensure_smbclient
    info "detecting SMB version for $server ..."
    local vers
    vers=$(detect_smb_version "$server" -U "${username}%${password}" -W "$domain")
    if [[ -n "$vers" ]]; then
        info "negotiated SMB $vers"
    else
        vers="3.1.1"
        warn "could not detect SMB version, defaulting to $vers"
    fi

    # Create credential file
    mkdir -p "$CRED_DIR"
    local cred_file="$CRED_DIR/cred-$name"
    cat > "$cred_file" <<EOF
username=${username}
password=${password}
domain=${domain}
EOF
    chmod 600 "$cred_file"
    info "credentials saved to $cred_file"

    # Create mount point
    mkdir -p "$MNT_DIR/$name"
    info "mount point created at $MNT_DIR/$name"

    # Add fstab entry and start automount
    fstab_add "$name" "$server" "$share" "$vers"
    automount_start "$name"

    echo "---"
    info "share '$name' configured. Access $MNT_DIR/$name to auto-mount."
}

cmd_remove() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "usage: mounty remove <name>"
    require_share "$name"

    # Unmount if mounted
    if is_mounted "$name"; then
        sudo umount "$MNT_DIR/$name" 2>/dev/null || warn "could not unmount $MNT_DIR/$name"
    fi

    # Stop automount unit
    automount_stop "$name"

    # Remove fstab entry
    fstab_remove "$name"

    # Remove credential file
    rm -f "$CRED_DIR/cred-$name"
    info "credentials removed"

    # Remove mount point (only if empty)
    if [[ -d "$MNT_DIR/$name" ]]; then
        rmdir "$MNT_DIR/$name" 2>/dev/null && info "mount point removed" || warn "mount point not empty, kept: $MNT_DIR/$name"
    fi

    sudo systemctl daemon-reload
    info "share '$name' removed"
}

cmd_mount() {
    local name="${1:-}"

    if [[ "$name" == "--all" ]]; then
        local shares
        shares=$(list_shares)
        [[ -z "$shares" ]] && die "no shares configured"
        while IFS= read -r s; do
            cmd_mount "$s"
        done <<< "$shares"
        return
    fi

    [[ -z "$name" ]] && die "usage: mounty mount <name|--all>"
    require_share "$name"

    if is_mounted "$name"; then
        info "'$name' is already mounted"
        return
    fi

    sudo mount "$MNT_DIR/$name"
    info "'$name' mounted at $MNT_DIR/$name"
}

cmd_unmount() {
    local name="${1:-}"

    if [[ "$name" == "--all" ]]; then
        local shares
        shares=$(list_shares)
        [[ -z "$shares" ]] && die "no shares configured"
        while IFS= read -r s; do
            cmd_unmount "$s"
        done <<< "$shares"
        return
    fi

    [[ -z "$name" ]] && die "usage: mounty unmount <name|--all>"
    require_share "$name"

    if ! is_mounted "$name"; then
        info "'$name' is not mounted"
        return
    fi

    sudo umount "$MNT_DIR/$name"
    info "'$name' unmounted"
}

cmd_list() {
    local shares
    shares=$(list_shares)

    if [[ -z "$shares" ]]; then
        echo "No shares configured."
        echo "Run: mounty add <name>"
        return
    fi

    printf "%-20s %-10s %s\n" "NAME" "STATUS" "MOUNT POINT"
    printf "%-20s %-10s %s\n" "----" "------" "-----------"

    while IFS= read -r name; do
        local status="unmounted"
        is_mounted "$name" && status="mounted"
        printf "%-20s %-10s %s\n" "$name" "$status" "$MNT_DIR/$name"
    done <<< "$shares"
}

cmd_status() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        # Show all shares
        local shares
        shares=$(list_shares)
        [[ -z "$shares" ]] && { echo "No shares configured."; return; }
        while IFS= read -r s; do
            cmd_status "$s"
            echo
        done <<< "$shares"
        return
    fi

    require_share "$name"

    local cred_file="$CRED_DIR/cred-$name"
    local fstab_line
    fstab_line=$(get_fstab_line "$name")

    echo "Share: $name"
    echo "  Mount point:  $MNT_DIR/$name"
    echo "  Credentials:  $cred_file"

    # Extract server/share from fstab
    if [[ -n "$fstab_line" ]]; then
        local remote
        remote=$(echo "$fstab_line" | awk '{print $1}')
        local opts
        opts=$(echo "$fstab_line" | awk '{print $4}')
        local vers
        vers=$(echo "$opts" | grep -oP 'vers=\K[^,]+' || echo "unknown")
        echo "  Remote:       $remote"
        echo "  SMB version:  $vers"
    else
        echo "  fstab:        NOT CONFIGURED (missing entry)"
    fi

    # Show credential info (without password)
    if [[ -f "$cred_file" ]]; then
        local user domain
        user=$(grep '^username=' "$cred_file" | cut -d= -f2-)
        domain=$(grep '^domain=' "$cred_file" | cut -d= -f2-)
        echo "  User:         ${domain}\\${user}"
    fi

    if is_mounted "$name"; then
        echo "  Status:       MOUNTED"
    else
        echo "  Status:       unmounted"
    fi
}

cmd_edit() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "usage: mounty edit <name>"
    require_share "$name"

    local cred_file="$CRED_DIR/cred-$name"

    echo "Editing share: $name"
    echo "Leave blank to keep current value."
    echo "---"

    # Read current values
    local cur_user cur_domain cur_server cur_share cur_vers
    cur_user=$(grep '^username=' "$cred_file" | cut -d= -f2-)
    cur_domain=$(grep '^domain=' "$cred_file" | cut -d= -f2-)

    local fstab_line
    fstab_line=$(get_fstab_line "$name")
    if [[ -n "$fstab_line" ]]; then
        local remote
        remote=$(echo "$fstab_line" | awk '{print $1}')
        cur_server=$(echo "$remote" | sed 's|^//||; s|/.*||')
        cur_share=$(echo "$remote" | sed 's|^//[^/]*/||')
        cur_vers=$(echo "$fstab_line" | grep -oP 'vers=\K[^,]+' || echo "3.1.1")
    else
        cur_server="" cur_share="" cur_vers="3.1.1"
    fi

    read -rp "Server [$cur_server]: " server
    server="${server:-$cur_server}"

    read -rp "Share [$cur_share]: " share
    share="${share:-$cur_share}"

    local cur_combined="${cur_domain}\\${cur_user}"
    local username="" domain=""
    read -rp "$USERNAME_HINT [$cur_combined]: " username
    if [[ -n "$username" ]]; then
        parse_username "$username" "$cur_domain"
    else
        username="$cur_user"
        domain="$cur_domain"
    fi

    read -rsp "Password [unchanged]: " password
    echo
    if [[ -z "$password" ]]; then
        password=$(grep '^password=' "$cred_file" | cut -d= -f2-)
    fi

    # Re-detect SMB version
    ensure_smbclient
    info "detecting SMB version for $server ..."
    local vers
    vers=$(detect_smb_version "$server" -U "${username}%${password}" -W "$domain")
    if [[ -n "$vers" ]]; then
        info "negotiated SMB $vers"
    else
        vers="$cur_vers"
        warn "could not detect SMB version, keeping $vers"
    fi

    # Was mounted?
    local was_mounted=false
    is_mounted "$name" && was_mounted=true

    # Unmount if needed
    if $was_mounted; then
        sudo umount "$MNT_DIR/$name" 2>/dev/null || true
    fi

    # Update credential file
    cat > "$cred_file" <<EOF
username=${username}
password=${password}
domain=${domain}
EOF
    chmod 600 "$cred_file"
    info "credentials updated"

    # Update fstab and restart automount
    automount_stop "$name"
    fstab_remove "$name"
    fstab_add "$name" "$server" "$share" "$vers"
    automount_start "$name"
    info "share '$name' updated"
}

cmd_browse() {
    local server="${1:-}"
    [[ -z "$server" ]] && die "usage: mounty browse <server>"

    ensure_smbclient

    # Ask for credentials (optional for anonymous access)
    local username="" password="" domain="WORKGROUP" auth_args=()

    read -rp "$USERNAME_HINT (blank for anonymous): " username
    if [[ -n "$username" ]]; then
        parse_username "$username"
        read -rsp "Password: " password
        echo
        auth_args=(-U "${username}%${password}" -W "$domain")
    else
        auth_args=(-N)
    fi

    info "browsing //$server ..."
    echo

    local raw_output
    if ! raw_output=$(smbclient -L "//$server" "${auth_args[@]}" -d 4 2>&1); then
        # smbclient may return non-zero but still list shares — check for output
        if ! echo "$raw_output" | grep -q "Disk\|IPC\|Printer"; then
            echo "$raw_output" >&2
            die "could not connect to $server"
        fi
    fi

    # Detect negotiated SMB version from debug output
    local dialect vers=""
    dialect=$(echo "$raw_output" | grep -oP 'negotiated dialect\[\K[^\]]+' | head -1)
    case "$dialect" in
        SMB3_11)  vers="3.1.1" ;;
        SMB3_02)  vers="3.0.2" ;;
        SMB3_00)  vers="3.0" ;;
        SMB2_10)  vers="2.1" ;;
        SMB2_02)  vers="2.0" ;;
        NT1)      vers="1.0" ;;
    esac
    if [[ -n "$vers" ]]; then
        info "negotiated SMB $vers"
    else
        vers="3.1.1"
        warn "could not detect SMB version, defaulting to $vers"
    fi

    # Parse share list: lines matching "sharename   Disk|Printer   comment"
    local -a share_names=()
    local -a share_types=()
    local -a share_comments=()

    while IFS= read -r line; do
        # smbclient output format: "\tShareName      Type      Comment"
        local name type comment
        name=$(echo "$line" | awk '{print $1}')
        type=$(echo "$line" | awk '{print $2}')
        comment=$(echo "$line" | sed 's/^[[:space:]]*[^[:space:]]*[[:space:]]*[^[:space:]]*[[:space:]]*//')

        # Skip IPC$ and hidden shares (ending with $) unless they're the only ones
        if [[ "$type" == "Disk" ]]; then
            share_names+=("$name")
            share_types+=("$type")
            share_comments+=("$comment")
        fi
    done < <(echo "$raw_output" | grep -P '^\s+\S+\s+(Disk|Printer)' || true)

    if [[ ${#share_names[@]} -eq 0 ]]; then
        die "no shares found on $server"
    fi

    # Display numbered list
    printf "  %-4s %-30s %s\n" "#" "SHARE" "COMMENT"
    printf "  %-4s %-30s %s\n" "--" "-----" "-------"
    for i in "${!share_names[@]}"; do
        printf "  %-4s %-30s %s\n" "$((i + 1))" "${share_names[$i]}" "${share_comments[$i]}"
    done
    echo

    # Let user pick
    read -rp "Select share to add [1-${#share_names[@]}, or q to quit]: " choice

    [[ "$choice" == "q" || -z "$choice" ]] && return

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#share_names[@]} )); then
        die "invalid selection: $choice"
    fi

    local selected_share="${share_names[$((choice - 1))]}"
    info "selected: $selected_share"
    echo

    # Suggest a mount name (lowercase, sanitized)
    local suggested_name
    suggested_name=$(echo "$selected_share" | tr '[:upper:]' '[:lower:]' | tr -c '[:alnum:]-' '-' | sed 's/-$//')
    read -rp "Mount name [$suggested_name]: " mount_name
    mount_name="${mount_name:-$suggested_name}"

    if share_exists "$mount_name"; then
        die "share '$mount_name' already exists. Use 'mounty edit $mount_name' or 'mounty remove $mount_name' first"
    fi

    # Reuse credentials from browse or prompt fresh
    if [[ -z "$username" ]]; then
        read -rp "$USERNAME_HINT: " username
        [[ -z "$username" ]] && die "username is required"
        parse_username "$username"
        read -rsp "Password: " password
        echo
        [[ -z "$password" ]] && die "password is required"
    fi

    ensure_deps

    # Create credential file
    mkdir -p "$CRED_DIR"
    local cred_file="$CRED_DIR/cred-$mount_name"
    cat > "$cred_file" <<EOF
username=${username}
password=${password}
domain=${domain}
EOF
    chmod 600 "$cred_file"
    info "credentials saved to $cred_file"

    # Create mount point
    mkdir -p "$MNT_DIR/$mount_name"
    info "mount point created at $MNT_DIR/$mount_name"

    # Add fstab entry and start automount
    fstab_add "$mount_name" "$server" "$selected_share" "$vers"
    automount_start "$mount_name"

    echo "---"
    info "share '$mount_name' configured. Access $MNT_DIR/$mount_name to auto-mount."
}

cmd_help() {
    cat <<'EOF'
mounty - Samba/CIFS share manager

Usage:
  mounty add <name>          Add a new share (interactive)
  mounty browse <server>     Browse available shares on a server
  mounty remove <name>       Remove a share and clean up
  mounty mount <name|--all>  Mount a share
  mounty unmount <name|--all> Unmount a share
  mounty list                List configured shares
  mounty status [name]       Show detailed share info
  mounty edit <name>         Edit share configuration
  mounty help                Show this help

Shares are mounted at ~/mnt/<name> using kernel CIFS.
Credentials are stored in ~/.mounty/cred-<name>.
EOF
}

# --- Main ---

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        add)     cmd_add "$@" ;;
        browse)  cmd_browse "$@" ;;
        remove|rm)  cmd_remove "$@" ;;
        mount)   cmd_mount "$@" ;;
        unmount|umount) cmd_unmount "$@" ;;
        list|ls) cmd_list "$@" ;;
        status)  cmd_status "$@" ;;
        edit)    cmd_edit "$@" ;;
        help|-h|--help) cmd_help ;;
        *)       die "unknown command: $cmd. Run: mounty help" ;;
    esac
}

main "$@"
