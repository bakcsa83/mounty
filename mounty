#!/usr/bin/env python3
"""mounty - Samba/CIFS share manager for KDE Plasma"""

import getpass
import os
import pwd
import re
import shlex
import shutil
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
CRED_DIR = HOME / ".mounty"
LIVE_DIR = HOME / ".mounty" / "live"
MNT_DIR = HOME / "mnt"
FSTAB = Path("/etc/fstab")
FSTAB_MARKER = "mounty"
FSTAB_BEGIN = "# >>> mounty managed mounts - do not edit manually >>>"
FSTAB_END = "# <<< mounty managed mounts <<<"
NM_DISPATCHER = Path("/etc/NetworkManager/dispatcher.d/50-mounty")
SLEEP_HOOK    = Path("/usr/lib/systemd/system-sleep/mounty")
HELPER        = Path("/usr/local/sbin/mounty-helper")

KWALLET_FOLDER = "mounty"
KWALLET_NAME = "kdewallet"
KWALLET_DBUS_DEST = "org.kde.kwalletd6"
KWALLET_DBUS_PATH = "/modules/kwalletd6"
KWALLET_DBUS_IFACE = "org.kde.KWallet"
KWALLET_APP_ID = "mounty"
USERNAME_HINT = "Username (DOMAIN\\user or user@DOMAIN)"

SMB_DIALECT_MAP = {
    "SMB3_11": "3.1.1",
    "SMB3_02": "3.0.2",
    "SMB3_00": "3.0",
    "SMB2_10": "2.1",
    "SMB2_02": "2.0",
    "NT1":     "1.0",
}


# --- Output helpers ---

def die(msg: str):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)

def info(msg: str):
    print(f":: {msg}")

def warn(msg: str):
    print(f"warning: {msg}", file=sys.stderr)


# --- Field validators ---
#
# Strict whitelists for any value written to /etc/fstab, used as a filesystem
# path component, or written into a credential file. Without these, whitespace
# or '#' in user input would let a crafted server/share/name inject extra
# fstab entries; a newline in a username would let it inject a 'password='
# line into the cred file (which mount.cifs would honour over the real one).

_NAME_RE   = re.compile(r"^[A-Za-z0-9._-]+$")
_SERVER_RE = re.compile(r"^[A-Za-z0-9._-]+$")
_SHARE_RE  = re.compile(r"^[A-Za-z0-9._$-]+$")

def _check_name(name: str):
    if name in (".", "..") or not _NAME_RE.match(name or ""):
        die(f"invalid share name '{name}': "
            "use letters, digits, '.', '_', '-' only (no '.' or '..')")

def _check_server(s: str):
    if not _SERVER_RE.match(s or ""):
        die(f"invalid server '{s}': use letters, digits, '.', '_', '-' only")

def _check_share(s: str):
    if not _SHARE_RE.match(s or ""):
        die(f"invalid share '{s}': use letters, digits, '.', '_', '$', '-' only")

def _check_credfield(field: str, value: str):
    if any(c in value for c in "\n\r\0"):
        die(f"invalid {field}: control characters not allowed")


# --- Subprocess helpers ---

def _run(*cmd):
    subprocess.run(list(cmd), check=True)

def _sudo(*cmd):
    _run("sudo", *cmd)

def _helper(*args, capture: bool = False) -> subprocess.CompletedProcess:
    """Invoke the privileged helper. install.sh sets up passwordless sudo
    for it so this works from the systemd user service and resume hooks."""
    if not HELPER.exists():
        die(f"{HELPER} not found. Re-run install.sh.")
    return subprocess.run(
        ["sudo", str(HELPER), *args],
        capture_output=capture,
    )

def _capture(*cmd, default: str = "") -> str:
    r = subprocess.run(list(cmd), capture_output=True, text=True)
    return r.stdout.strip() if r.returncode == 0 else default


# --- Dependency checks ---

def ensure_deps():
    if not shutil.which("mount.cifs"):
        print("cifs-utils is not installed.")
        if input("Install it now? [Y/n] ").strip().lower() != "n":
            _sudo("apt", "install", "-y", "cifs-utils")
        else:
            die("cifs-utils is required")

def ensure_smbclient():
    if not shutil.which("smbclient"):
        print("smbclient is not installed (needed for browsing).")
        if input("Install it now? [Y/n] ").strip().lower() != "n":
            _sudo("apt", "install", "-y", "smbclient")
        else:
            die("smbclient is required for browsing")

def ensure_kwallet():
    if not shutil.which("dbus-send"):
        die("dbus-send not found. Install dbus: sudo apt install dbus")


# --- KDE Wallet (via dbus-send) ---

def _dbus(method: str, *args) -> str:
    r = subprocess.run(
        ["dbus-send", "--session", f"--dest={KWALLET_DBUS_DEST}", "--print-reply",
         KWALLET_DBUS_PATH, f"{KWALLET_DBUS_IFACE}.{method}", *args],
        capture_output=True, text=True,
    )
    return r.stdout if r.returncode == 0 else ""

def _dbus_int(output: str) -> str:
    m = re.search(r"int32 (-?\d+)", output)
    return m.group(1) if m else ""

def _dbus_str(output: str) -> str:
    m = re.search(r'^\s*string "(.*)"$', output, re.MULTILINE)
    return m.group(1) if m else ""

def kwallet_open() -> str:
    out = _dbus("open", f"string:{KWALLET_NAME}", "int64:0", f"string:{KWALLET_APP_ID}")
    handle = _dbus_int(out)
    if not handle or handle == "-1":
        die(f"failed to open KDE Wallet. Ensure '{KWALLET_NAME}' is open.")
    return handle

def kwallet_ensure_folder(handle: str):
    _dbus("createFolder", f"int32:{handle}", f"string:{KWALLET_FOLDER}",
          f"string:{KWALLET_APP_ID}")

def kwallet_store(name: str, password: str):
    handle = kwallet_open()
    kwallet_ensure_folder(handle)
    out = _dbus("writePassword", f"int32:{handle}", f"string:{KWALLET_FOLDER}",
                f"string:cred-{name}", f"string:{password}", f"string:{KWALLET_APP_ID}")
    if _dbus_int(out) != "0":
        die("failed to store password in KDE Wallet")

def kwallet_read(name: str) -> str:
    handle = kwallet_open()
    out = _dbus("readPassword", f"int32:{handle}", f"string:{KWALLET_FOLDER}",
                f"string:cred-{name}", f"string:{KWALLET_APP_ID}")
    return _dbus_str(out)

def kwallet_remove(name: str):
    handle = kwallet_open()
    _dbus("removeEntry", f"int32:{handle}", f"string:{KWALLET_FOLDER}",
          f"string:cred-{name}", f"string:{KWALLET_APP_ID}")


# --- Helpers ---

def parse_username(s: str, default_domain: str = "WORKGROUP") -> tuple[str, str]:
    """Return (username, domain)."""
    if "\\" in s:
        domain, username = s.split("\\", 1)
    elif "@" in s:
        username, domain = s.split("@", 1)
    else:
        username, domain = s, default_domain
    return username, domain

def detect_smb_version(server: str, auth_args: list[str]) -> str:
    r = subprocess.run(
        ["smbclient", "-L", f"//{server}", *auth_args, "-d", "4"],
        capture_output=True, text=True,
    )
    m = re.search(r"negotiated dialect\[([^\]]+)\]", r.stdout + r.stderr)
    return SMB_DIALECT_MAP.get(m.group(1), "") if m else ""


# --- Live credentials (tmpfs) ---

def is_unlocked() -> bool:
    return subprocess.run(
        ["mountpoint", "-q", str(LIVE_DIR)], capture_output=True
    ).returncode == 0

def require_unlocked():
    if not is_unlocked():
        die("mounty is locked. Run: mounty unlock")

def write_live_cred(name: str, password: str = "") -> bool:
    cred_file = CRED_DIR / f"cred-{name}"
    if not cred_file.exists():
        return False
    lines = cred_file.read_text().splitlines()
    username = next((l.split("=", 1)[1] for l in lines if l.startswith("username=")), "")
    domain   = next((l.split("=", 1)[1] for l in lines if l.startswith("domain=")),   "")
    if not password:
        password = kwallet_read(name)
    if not password:
        warn(f"no password available for '{name}'")
        return False
    live = LIVE_DIR / f"cred-{name}"
    live.write_text(f"username={username}\npassword={password}\ndomain={domain}\n")
    live.chmod(0o600)
    return True

def share_exists(name: str) -> bool:
    return (CRED_DIR / f"cred-{name}").exists()

def require_share(name: str):
    _check_name(name)
    if not share_exists(name):
        die(f"share '{name}' not found. Run: mounty list")

def list_shares() -> list[str]:
    if not CRED_DIR.is_dir():
        return []
    return sorted(
        f.name[5:] for f in CRED_DIR.iterdir()
        if f.name.startswith("cred-") and f.is_file()
    )

def is_mounted(name: str) -> bool:
    return subprocess.run(
        ["mountpoint", "-q", str(MNT_DIR / name)], capture_output=True
    ).returncode == 0

def _umount_live() -> bool:
    """Unmount the credentials tmpfs via the helper (lazy fallback inside)."""
    return _helper("umount-tmpfs", capture=True).returncode == 0

def _umount_share(name: str) -> bool:
    """Unmount a share's mountpoint via the helper (lazy fallback inside)."""
    return _helper("umount-share", name, capture=True).returncode == 0


# --- fstab ---

def automount_unit_name(name: str) -> str:
    return _capture("systemd-escape", "-p", str(MNT_DIR / name)) + ".automount"

def automount_start(name: str):
    _helper("daemon-reload")
    _helper("automount", "start", name)
    info(f"automount active for {MNT_DIR / name}")

def automount_stop(name: str):
    _helper("automount", "stop", name, capture=True)

def _recover_automounts() -> int:
    """Reset and restart any failed automount units. Returns number recovered."""
    recovered = 0
    for name in list_shares():
        if not get_fstab_line(name):
            continue
        unit       = automount_unit_name(name)
        state      = _capture("systemctl", "show", "-p", "ActiveState", "--value", unit)
        result_val = _capture("systemctl", "show", "-p", "Result",      "--value", unit)
        if state != "active" or result_val != "success":
            _helper("automount", "reset-failed", name, capture=True)
            _helper("automount", "restart",      name, capture=True)
            info(f"recovered {name}")
            recovered += 1
    return recovered

def fstab_read() -> str:
    return FSTAB.read_text()

def fstab_write(content: str):
    p = subprocess.Popen(
        ["sudo", "tee", str(FSTAB)], stdin=subprocess.PIPE, stdout=subprocess.DEVNULL
    )
    p.communicate(content.encode())
    if p.returncode != 0:
        die("failed to write /etc/fstab")

def fstab_backup():
    _sudo("cp", str(FSTAB), str(FSTAB) + ".bak.mounty")

def fstab_has_section() -> bool:
    return FSTAB_BEGIN in fstab_read()

def fstab_ensure_section():
    if not fstab_has_section():
        content = fstab_read().rstrip("\n") + f"\n\n{FSTAB_BEGIN}\n{FSTAB_END}\n"
        fstab_write(content)

def fstab_section_is_empty() -> bool:
    in_section = False
    for line in fstab_read().splitlines():
        if line == FSTAB_BEGIN:
            in_section = True
            continue
        if line == FSTAB_END:
            break
        if in_section and line.strip() and not line.startswith("#"):
            return False
    return True

def fstab_remove_section():
    lines = fstab_read().split("\n")
    result, skip = [], False
    for line in lines:
        if line == FSTAB_BEGIN:
            skip = True
            if result and result[-1] == "":
                result.pop()
            continue
        if line == FSTAB_END:
            skip = False
            continue
        if not skip:
            result.append(line)
    while result and result[-1] == "":
        result.pop()
    fstab_write("\n".join(result) + "\n")

def get_fstab_line(name: str) -> str:
    marker = f"# {FSTAB_MARKER}:{name}"
    for line in fstab_read().splitlines():
        if line.endswith(marker):
            return line
    return ""

def fstab_add(name: str, server: str, share: str, vers: str):
    _check_name(name)
    _check_server(server)
    _check_share(share)
    uid, gid = os.getuid(), os.getgid()
    opts = (
        f"credentials={LIVE_DIR}/cred-{name},vers={vers},uid={uid},gid={gid},"
        f"file_mode=0644,dir_mode=0755,_netdev,x-systemd.automount,"
        f"x-systemd.idle-timeout=5min,nofail"
    )
    entry = f"//{server}/{share} {MNT_DIR}/{name} cifs {opts} 0 0 # {FSTAB_MARKER}:{name}"
    fstab_backup()
    fstab_ensure_section()
    lines = fstab_read().split("\n")
    result = []
    for line in lines:
        if line == FSTAB_END:
            result.append(entry)
        result.append(line)
    fstab_write("\n".join(result))
    info("fstab entry added")

def fstab_remove(name: str):
    if not get_fstab_line(name):
        return
    fstab_backup()
    marker = f"# {FSTAB_MARKER}:{name}"
    content = "\n".join(
        l for l in fstab_read().split("\n") if not l.endswith(marker)
    )
    fstab_write(content)
    info("fstab entry removed")
    if fstab_section_is_empty():
        fstab_remove_section()
        info("fstab section removed (no shares left)")


# --- Commands ---

def cmd_unlock():
    ensure_kwallet()

    if is_unlocked():
        # tmpfs already mounted - verify all credential files are present
        # (recovers from a crashed previous run that left tmpfs but lost creds)
        repaired = 0
        for name in list_shares():
            if not (LIVE_DIR / f"cred-{name}").exists():
                if write_live_cred(name):
                    repaired += 1
        if repaired:
            info(f"repopulated {repaired} missing credential file(s)")
        else:
            info("already unlocked")
    else:
        LIVE_DIR.mkdir(parents=True, exist_ok=True)
        _helper("mount-tmpfs")
        info(f"tmpfs mounted at {LIVE_DIR}")
        shares = list_shares()
        count  = sum(1 for name in shares if write_live_cred(name))
        info(f"{count} share credential(s) loaded from KDE Wallet")

    # Always reset failed automounts so anything that tried to access a share
    # before unlock (Dolphin Places, indexers, etc.) gets unstuck.
    _recover_automounts()

def cmd_lock():
    for name in list_shares():
        if is_mounted(name):
            if not _umount_share(name):
                warn(f"could not unmount {name}")
        automount_stop(name)
    if is_unlocked():
        _umount_live()
        info("tmpfs unmounted — credentials cleared from RAM")
    else:
        info("already locked")

def cmd_add(name: str):
    _check_name(name)
    if share_exists(name):
        die(f"share '{name}' already exists. Use 'mounty edit {name}' or 'mounty remove {name}' first")
    ensure_deps()
    ensure_kwallet()

    print(f"Adding share: {name}")
    print("---")
    server = input("Server (hostname or IP): ").strip()
    if not server:
        die("server is required")
    _check_server(server)
    share = input("Share name: ").strip()
    if not share:
        die("share name is required")
    _check_share(share)
    raw_user = input(f"{USERNAME_HINT}: ").strip()
    if not raw_user:
        die("username is required")
    username, domain = parse_username(raw_user)
    _check_credfield("username", username)
    _check_credfield("domain", domain)
    password = getpass.getpass("Password: ")
    if not password:
        die("password is required")

    ensure_smbclient()
    info(f"detecting SMB version for {server} ...")
    vers = detect_smb_version(server, ["-U", f"{username}%{password}", "-W", domain])
    if vers:
        info(f"negotiated SMB {vers}")
    else:
        vers = "3.1.1"
        warn(f"could not detect SMB version, defaulting to {vers}")

    kwallet_store(name, password)
    info("password stored in KDE Wallet")

    CRED_DIR.mkdir(parents=True, exist_ok=True)
    cred_file = CRED_DIR / f"cred-{name}"
    cred_file.write_text(f"username={username}\ndomain={domain}\n")
    cred_file.chmod(0o600)
    info(f"credentials saved to {cred_file} (password in wallet only)")

    (MNT_DIR / name).mkdir(parents=True, exist_ok=True)
    info(f"mount point created at {MNT_DIR / name}")

    if not is_unlocked():
        cmd_unlock()
    write_live_cred(name, password)
    fstab_add(name, server, share, vers)
    automount_start(name)

    print("---")
    info(f"share '{name}' configured. Access {MNT_DIR / name} to auto-mount.")

def cmd_remove(name: str):
    require_share(name)
    if is_mounted(name):
        if not _umount_share(name):
            warn(f"could not unmount {MNT_DIR / name}")
    automount_stop(name)
    fstab_remove(name)
    (LIVE_DIR / f"cred-{name}").unlink(missing_ok=True)
    kwallet_remove(name)
    info("password removed from KDE Wallet")
    (CRED_DIR / f"cred-{name}").unlink(missing_ok=True)
    info("credentials removed")
    mnt = MNT_DIR / name
    if mnt.is_dir():
        try:
            mnt.rmdir()
            info("mount point removed")
        except OSError:
            warn(f"mount point not empty, kept: {mnt}")
    _helper("daemon-reload")
    info(f"share '{name}' removed")

def cmd_mount(name: str):
    if name == "--all":
        shares = list_shares()
        if not shares:
            die("no shares configured")
        for s in shares:
            cmd_mount(s)
        return
    require_share(name)
    require_unlocked()
    if is_mounted(name):
        info(f"'{name}' is already mounted")
        return
    _helper("mount-share", name)
    info(f"'{name}' mounted at {MNT_DIR / name}")

def cmd_unmount(name: str):
    if name == "--all":
        shares = list_shares()
        if not shares:
            die("no shares configured")
        for s in shares:
            cmd_unmount(s)
        return
    require_share(name)
    if not is_mounted(name):
        info(f"'{name}' is not mounted")
        return
    if not _umount_share(name):
        die(f"failed to unmount '{name}'")
    info(f"'{name}' unmounted")

def cmd_list():
    shares = list_shares()
    if not shares:
        print("No shares configured.")
        print("Run: mounty add <name>")
        return
    print(f"Vault: {'unlocked' if is_unlocked() else 'LOCKED'}")
    print()
    print(f"{'NAME':<20} {'STATUS':<10} MOUNT POINT")
    print(f"{'----':<20} {'------':<10} -----------")
    for name in shares:
        status = "mounted" if is_mounted(name) else "unmounted"
        print(f"{name:<20} {status:<10} {MNT_DIR / name}")

def cmd_status(name: str = ""):
    if not name:
        shares = list_shares()
        if not shares:
            print("No shares configured.")
            return
        vault = f"unlocked (tmpfs at {LIVE_DIR})" if is_unlocked() else "LOCKED"
        print(f"Vault: {vault}")
        print()
        for s in shares:
            cmd_status(s)
            print()
        return
    require_share(name)
    cred_file = CRED_DIR / f"cred-{name}"
    live      = LIVE_DIR  / f"cred-{name}"
    fstab_line = get_fstab_line(name)
    print(f"Share: {name}")
    print(f"  Mount point:  {MNT_DIR / name}")
    print(f"  Config:       {cred_file}")
    print(f"  Live creds:   {live} {'(ready)' if live.exists() else '(missing)'}")
    print(f"  Wallet:       {KWALLET_FOLDER}/cred-{name}")
    if fstab_line:
        parts  = fstab_line.split()
        remote = parts[0] if parts else "unknown"
        opts   = parts[3] if len(parts) > 3 else ""
        m = re.search(r"vers=([^,]+)", opts)
        print(f"  Remote:       {remote}")
        print(f"  SMB version:  {m.group(1) if m else 'unknown'}")
    else:
        print("  fstab:        NOT CONFIGURED (missing entry)")
    if cred_file.exists():
        lines  = cred_file.read_text().splitlines()
        user   = next((l.split("=", 1)[1] for l in lines if l.startswith("username=")), "")
        domain = next((l.split("=", 1)[1] for l in lines if l.startswith("domain=")),   "")
        print(f"  User:         {domain}\\{user}")
    print(f"  Status:       {'MOUNTED' if is_mounted(name) else 'unmounted'}")

def cmd_edit(name: str):
    require_share(name)
    ensure_kwallet()
    cred_file = CRED_DIR / f"cred-{name}"
    print(f"Editing share: {name}")
    print("Leave blank to keep current value.")
    print("---")

    lines      = cred_file.read_text().splitlines()
    cur_user   = next((l.split("=", 1)[1] for l in lines if l.startswith("username=")), "")
    cur_domain = next((l.split("=", 1)[1] for l in lines if l.startswith("domain=")),   "")

    fstab_line = get_fstab_line(name)
    cur_server = cur_share = ""
    cur_vers = "3.1.1"
    if fstab_line:
        parts  = fstab_line.split()
        remote = parts[0] if parts else ""
        m = re.match(r"//([^/]+)/(.*)", remote)
        if m:
            cur_server, cur_share = m.group(1), m.group(2)
        opts = parts[3] if len(parts) > 3 else ""
        mv = re.search(r"vers=([^,]+)", opts)
        if mv:
            cur_vers = mv.group(1)

    server = input(f"Server [{cur_server}]: ").strip() or cur_server
    _check_server(server)
    share  = input(f"Share [{cur_share}]: ").strip()   or cur_share
    _check_share(share)

    raw_user = input(f"{USERNAME_HINT} [{cur_domain}\\{cur_user}]: ").strip()
    if raw_user:
        username, domain = parse_username(raw_user, cur_domain)
    else:
        username, domain = cur_user, cur_domain
    _check_credfield("username", username)
    _check_credfield("domain", domain)

    password = getpass.getpass("Password [unchanged]: ")
    if not password:
        password = kwallet_read(name)
        if not password:
            die("no existing password in wallet and none provided")

    ensure_smbclient()
    info(f"detecting SMB version for {server} ...")
    vers = detect_smb_version(server, ["-U", f"{username}%{password}", "-W", domain])
    if vers:
        info(f"negotiated SMB {vers}")
    else:
        vers = cur_vers
        warn(f"could not detect SMB version, keeping {vers}")

    kwallet_store(name, password)
    info("password updated in KDE Wallet")
    cred_file.write_text(f"username={username}\ndomain={domain}\n")
    cred_file.chmod(0o600)
    info("credentials updated")

    if is_unlocked():
        write_live_cred(name, password)

    automount_stop(name)
    fstab_remove(name)
    fstab_add(name, server, share, vers)
    automount_start(name)
    info(f"share '{name}' updated")

def cmd_browse(server: str):
    _check_server(server)
    ensure_smbclient()
    ensure_kwallet()

    raw_user = input(f"{USERNAME_HINT} (blank for anonymous): ").strip()
    username = password = ""
    domain   = "WORKGROUP"
    auth_args: list[str] = []
    if raw_user:
        username, domain = parse_username(raw_user)
        _check_credfield("username", username)
        _check_credfield("domain", domain)
        password  = getpass.getpass("Password: ")
        auth_args = ["-U", f"{username}%{password}", "-W", domain]
    else:
        auth_args = ["-N"]

    info(f"browsing //{server} ...")
    print()

    r = subprocess.run(
        ["smbclient", "-L", f"//{server}", *auth_args, "-d", "4"],
        capture_output=True, text=True,
    )
    raw = r.stdout + r.stderr

    if r.returncode != 0 and not re.search(r"Disk|IPC|Printer", raw):
        print(raw, file=sys.stderr)
        die(f"could not connect to {server}")

    m = re.search(r"negotiated dialect\[([^\]]+)\]", raw)
    vers = SMB_DIALECT_MAP.get(m.group(1), "") if m else ""
    if vers:
        info(f"negotiated SMB {vers}")
    else:
        vers = "3.1.1"
        warn("could not detect SMB version, defaulting to 3.1.1")

    share_names:    list[str] = []
    share_comments: list[str] = []
    for line in raw.splitlines():
        sm = re.match(r"^\s+(\S+)\s+Disk\s*(.*)", line)
        if sm:
            share_names.append(sm.group(1))
            share_comments.append(sm.group(2).strip())

    if not share_names:
        die(f"no shares found on {server}")

    print(f"  {'#':<4} {'SHARE':<30} COMMENT")
    print(f"  {'--':<4} {'-----':<30} -------")
    for i, (sname, comment) in enumerate(zip(share_names, share_comments), 1):
        print(f"  {i:<4} {sname:<30} {comment}")
    print()

    choice = input(f"Select share to add [1-{len(share_names)}, or q to quit]: ").strip()
    if not choice or choice.lower() == "q":
        return
    if not choice.isdigit() or not (1 <= int(choice) <= len(share_names)):
        die(f"invalid selection: {choice}")

    selected = share_names[int(choice) - 1]
    _check_share(selected)
    info(f"selected: {selected}")
    print()

    suggested  = re.sub(r"[^a-z0-9-]", "-", selected.lower()).rstrip("-")
    mount_name = input(f"Mount name [{suggested}]: ").strip() or suggested
    _check_name(mount_name)

    if share_exists(mount_name):
        die(f"share '{mount_name}' already exists. Use 'mounty edit {mount_name}' or 'mounty remove {mount_name}' first")

    if not username:
        raw_user = input(f"{USERNAME_HINT}: ").strip()
        if not raw_user:
            die("username is required")
        username, domain = parse_username(raw_user)
        _check_credfield("username", username)
        _check_credfield("domain", domain)
        password = getpass.getpass("Password: ")
        if not password:
            die("password is required")

    ensure_deps()
    kwallet_store(mount_name, password)
    info("password stored in KDE Wallet")

    CRED_DIR.mkdir(parents=True, exist_ok=True)
    cred_file = CRED_DIR / f"cred-{mount_name}"
    cred_file.write_text(f"username={username}\ndomain={domain}\n")
    cred_file.chmod(0o600)
    info(f"credentials saved to {cred_file} (password in wallet only)")

    (MNT_DIR / mount_name).mkdir(parents=True, exist_ok=True)
    info(f"mount point created at {MNT_DIR / mount_name}")

    if not is_unlocked():
        cmd_unlock()
    write_live_cred(mount_name, password)
    fstab_add(mount_name, server, selected, vers)
    automount_start(mount_name)

    print("---")
    info(f"share '{mount_name}' configured. Access {MNT_DIR / mount_name} to auto-mount.")

def cmd_reconnect():
    shares = list_shares()
    if not shares:
        return
    if not is_unlocked():
        info("vault is locked, unlocking first...")
        cmd_unlock()
    for name in shares:
        if is_mounted(name):
            _umount_share(name)
    recovered = _recover_automounts()
    if recovered == 0:
        info("all automounts healthy")
    else:
        info(f"{recovered} share(s) recovered")

def _current_user() -> str:
    return (os.environ.get("SUDO_USER") or os.environ.get("USER")
            or pwd.getpwuid(os.getuid()).pw_name)

def _hook_script(self_path: str, user: str, trigger: str) -> str:
    """Generate a /bin/sh hook script that dispatches `mounty reconnect` to
    the install-time user with their session bus and runtime dir.

    The hook itself runs as root (NM dispatchers and system-sleep hooks both
    do); without dispatching to the user, mounty cannot reach KDE Wallet."""
    if trigger == "nm":
        guard = ('case "$2" in\n'
                 '    up|vpn-up|vpn-down|connectivity-change) ;;\n'
                 '    *) exit 0 ;;\n'
                 'esac')
        delay = 2
    elif trigger == "sleep":
        guard = '[ "$1" = "post" ] || exit 0'
        delay = 3
    else:
        die(f"unknown hook trigger: {trigger}")

    target_user = shlex.quote(user)
    cmd_path    = shlex.quote(self_path)
    return f"""#!/bin/sh
# Installed by mounty - {trigger} hook for auto-recovery

{guard}

TARGET_USER={target_user}
USER_ID=$(id -u "$TARGET_USER" 2>/dev/null)
[ -n "$USER_ID" ] || exit 0

# Skip if the user has no active session (e.g. boot before login)
loginctl show-user "$TARGET_USER" --property=State --value 2>/dev/null \\
    | grep -q active || exit 0

# Run in background so we never block resume / NM
(
    sleep {delay}
    runuser -u "$TARGET_USER" -- env \\
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$USER_ID/bus" \\
        XDG_RUNTIME_DIR="/run/user/$USER_ID" \\
        {cmd_path} reconnect >/dev/null 2>&1
) &
"""

def _write_root_file(path: Path, content: str):
    p = subprocess.Popen(
        ["sudo", "tee", str(path)], stdin=subprocess.PIPE, stdout=subprocess.DEVNULL
    )
    p.communicate(content.encode())
    if p.returncode != 0:
        die(f"failed to write {path}")
    _sudo("chmod", "755", str(path))

def cmd_install_dispatcher():
    self_path = os.path.realpath(sys.argv[0])
    user      = _current_user()

    _write_root_file(NM_DISPATCHER, _hook_script(self_path, user, "nm"))
    info(f"NetworkManager dispatcher installed at {NM_DISPATCHER}")

    _write_root_file(SLEEP_HOOK, _hook_script(self_path, user, "sleep"))
    info(f"systemd-sleep hook installed at {SLEEP_HOOK}")

    info(f"auto-recovery hooks active for user '{user}' "
         "(VPN/network changes, resume from suspend)")

def cmd_remove_dispatcher():
    removed = 0
    if NM_DISPATCHER.exists():
        _sudo("rm", str(NM_DISPATCHER))
        info("NetworkManager dispatcher removed")
        removed += 1
    if SLEEP_HOOK.exists():
        _sudo("rm", str(SLEEP_HOOK))
        info("systemd-sleep hook removed")
        removed += 1
    if removed == 0:
        info("no hooks installed")

def cmd_help():
    print("""\
mounty - Samba/CIFS share manager

Usage:
  mounty unlock              Load passwords from KDE Wallet into RAM
  mounty lock                Clear credentials from RAM, unmount all
  mounty add <name>          Add a new share (interactive)
  mounty browse <server>     Browse available shares on a server
  mounty remove <name>       Remove a share and clean up
  mounty mount <name|--all>  Mount a share
  mounty unmount <name|--all> Unmount a share
  mounty list                List configured shares
  mounty status [name]       Show detailed share info
  mounty edit <name>         Edit share configuration
  mounty reconnect           Reset failed automounts (e.g. after VPN, resume)
  mounty install-dispatcher  Install auto-recovery hooks (network, resume)
  mounty remove-dispatcher   Remove the auto-recovery hooks
  mounty help                Show this help

Passwords are stored in KDE Wallet. Live credentials are held in
a tmpfs (RAM) at ~/.mounty/live/ — nothing touches disk.

Shares are mounted at ~/mnt/<name> using kernel CIFS.""")


# --- Main ---

def main():
    args = sys.argv[1:]
    cmd  = args[0] if args else "help"
    rest = args[1:]

    if cmd in ("unlock",):
        cmd_unlock()
    elif cmd in ("lock",):
        cmd_lock()
    elif cmd == "add":
        cmd_add(rest[0]) if rest else die("usage: mounty add <name>")
    elif cmd == "browse":
        cmd_browse(rest[0]) if rest else die("usage: mounty browse <server>")
    elif cmd in ("remove", "rm"):
        cmd_remove(rest[0]) if rest else die("usage: mounty remove <name>")
    elif cmd == "mount":
        cmd_mount(rest[0]) if rest else die("usage: mounty mount <name|--all>")
    elif cmd in ("unmount", "umount"):
        cmd_unmount(rest[0]) if rest else die("usage: mounty unmount <name|--all>")
    elif cmd in ("list", "ls"):
        cmd_list()
    elif cmd == "status":
        cmd_status(rest[0] if rest else "")
    elif cmd == "edit":
        cmd_edit(rest[0]) if rest else die("usage: mounty edit <name>")
    elif cmd == "reconnect":
        cmd_reconnect()
    elif cmd == "install-dispatcher":
        cmd_install_dispatcher()
    elif cmd == "remove-dispatcher":
        cmd_remove_dispatcher()
    elif cmd in ("help", "-h", "--help"):
        cmd_help()
    else:
        die(f"unknown command: {cmd}. Run: mounty help")


if __name__ == "__main__":
    main()
